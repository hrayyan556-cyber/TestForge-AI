# LLM_PROVIDER options:
# auto    = use OpenAI if key exists, otherwise try Ollama, otherwise fallback demo generator
# ollama  = force local Ollama model
# openai  = force OpenAI API
# fallback = force template demo generator
LLM_PROVIDER=ollama

# OpenAI is optional. Leave empty if you want to use Ollama locally.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Ollama local LLM settings.
# Install Ollama, then run: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=120

DATABASE_URL=sqlite:///./qa_generator.db
